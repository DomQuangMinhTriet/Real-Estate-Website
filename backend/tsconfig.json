{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "../frontend/src/app/admin/blog-manage/blog-manage.component.ts", "../frontend/src/app/admin/blog-manage/blog-editor.component.ts"],
  "exclude": ["node_modules", "dist"]
}